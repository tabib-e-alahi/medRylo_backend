model Supplier {
  id            String    @id @default(cuid())
  name          String
  contactPerson String?
  email         String?   @unique
  phone         String?
  address       String?
  isActive      Boolean   @default(true)
  isDeleted     Boolean   @default(false)
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  medicines Medicine[]
  purchases Purchase[]

  @@map("suppliers")
}

model Customer {
  id         String    @id @default(cuid())
  pharmacyId String
  name       String
  email      String?
  phone      String?
  address    String?
  isDeleted  Boolean   @default(false)
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  pharmacy Pharmacy  @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  invoices Invoice[]

  @@map("customers")
}

model Purchase {
  id              String         @id @default(cuid())
  pharmacyId      String
  supplierId      String
  invoiceNumber   String         @map("invoiceNo")
  purchaseDate    DateTime       @default(now())
  subtotal        Decimal        @default(0) @db.Decimal(12, 2)
  vatAmount       Decimal        @default(0) @db.Decimal(12, 2)
  discount        Decimal        @default(0) @db.Decimal(12, 2)
  totalAmount     Decimal        @db.Decimal(12, 2)
  paidAmount      Decimal        @default(0) @db.Decimal(12, 2)
  dueAmount       Decimal        @default(0) @db.Decimal(12, 2)
  paymentStatus   PaymentStatus  @default(UNPAID)
  purchaseStatus  PurchaseStatus @default(PENDING) @map("status")
  note            String?        @map("notes")
  createdByUserId String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  pharmacy Pharmacy       @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  supplier Supplier       @relation(fields: [supplierId], references: [id])
  items    PurchaseItem[]

  @@unique([pharmacyId, invoiceNumber])
  @@index([pharmacyId, purchaseStatus])
  @@index([supplierId])
  @@map("purchases")
}

model PurchaseItem {
  id            String    @id @default(cuid())
  purchaseId    String
  inventoryId   String?
  medicineId    String
  quantity      Int
  purchasePrice Decimal   @map("unitPrice") @db.Decimal(10, 2)
  sellingPrice  Decimal   @default(0) @db.Decimal(10, 2)
  expiryDate    DateTime?
  batchNumber   String?
  total         Decimal   @map("totalPrice") @db.Decimal(10, 2)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  purchase  Purchase           @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  inventory PharmacyInventory? @relation(fields: [inventoryId], references: [id])
  medicine  Medicine           @relation(fields: [medicineId], references: [id])

  @@index([inventoryId])
  @@index([medicineId])
  @@map("purchase_items")
}

model Invoice {
  id              String        @id @default(cuid())
  pharmacyId      String
  customerId      String?
  invoiceNumber   String        @map("invoiceNo")
  saleDate        DateTime      @default(now()) @map("invoiceDate")
  subtotal        Decimal       @default(0) @db.Decimal(12, 2)
  vatAmount       Decimal       @default(0) @db.Decimal(10, 2)
  discount        Decimal       @default(0) @db.Decimal(10, 2)
  totalAmount     Decimal       @db.Decimal(12, 2)
  netAmount       Decimal       @db.Decimal(12, 2)
  paidAmount      Decimal       @default(0) @db.Decimal(12, 2)
  dueAmount       Decimal       @default(0) @db.Decimal(12, 2)
  paymentMode     PaymentMode   @default(CASH)
  paymentStatus   PaymentStatus @default(UNPAID)
  status          InvoiceStatus @default(DRAFT)
  note            String?       @map("notes")
  createdByUserId String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  pharmacy Pharmacy      @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  customer Customer?     @relation(fields: [customerId], references: [id])
  items    InvoiceItem[]
  payments Payment[]

  @@unique([pharmacyId, invoiceNumber])
  @@index([pharmacyId, paymentStatus])
  @@index([customerId])
  @@map("invoices")
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  inventoryId String?
  medicineId  String
  quantity    Int
  unitPrice   Decimal  @db.Decimal(10, 2)
  vat         Decimal  @default(0) @map("vatPercent") @db.Decimal(10, 2)
  discount    Decimal  @default(0) @db.Decimal(10, 2)
  total       Decimal  @map("totalPrice") @db.Decimal(10, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  invoice   Invoice            @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  inventory PharmacyInventory? @relation(fields: [inventoryId], references: [id])
  medicine  Medicine           @relation(fields: [medicineId], references: [id])

  @@index([inventoryId])
  @@index([medicineId])
  @@map("invoice_items")
}

model Payment {
  id               String      @id @default(cuid())
  invoiceId        String
  pharmacyId       String
  amount           Decimal     @db.Decimal(12, 2)
  paymentMode      PaymentMode @default(CASH)
  paymentDate      DateTime    @default(now())
  note             String?
  receivedByUserId String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  invoice  Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  pharmacy Pharmacy @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([pharmacyId])
  @@map("payments")
}
